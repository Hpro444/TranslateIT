# Copy this file to .env and replace the values with real secrets.
# Keeping this file checked in allows developers to see which variables are required.

# LibreTranslate (optional)
LIBRE_API_URL=https://libretranslate.com
LIBRE_API_KEY=

# Yandex Translate (optional)
YANDEX_API_KEY=

# Microsoft Azure Translator (optional)
MICROSOFT_API_KEY=
MICROSOFT_REGION=

